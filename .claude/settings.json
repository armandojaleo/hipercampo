{
  "env": {
    "HIPERCAMPO_LINKED": "*"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m hipercampo.cli hook",
            "timeout": 15,
            "statusMessage": "recordando quién soy trabajando..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m hipercampo.cli hook",
            "timeout": 15,
            "statusMessage": "consultando la memoria..."
          }
        ]
      }
    ]
  }
}
